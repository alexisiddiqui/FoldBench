Bootstrap: docker
From: nvidia/cuda:12.6.1-cudnn-devel-ubuntu22.04
Stage: builder

%files
    openfold-3/environments/production-linux-aarch64.yml /opt/openfold3/production-linux-aarch64.yml
    openfold-3/pyproject.toml                            /opt/openfold3/pyproject.toml
    openfold-3/openfold3                                 /opt/openfold3/openfold3
    openfold-3/scripts                                   /opt/openfold3/scripts

%post -c /bin/bash
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive

    # Build variables
    : "${MINIFORGE_VERSION:=25.11.0-1}"
    : "${TORCH_CUDA_ARCH_LIST:=9.0}"

    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        wget \
        git \
        build-essential \
        ninja-build \
        libaio-dev \
      && rm -rf /var/lib/apt/lists/*

    # Install Miniforge with auto-arch detection
    ARCH="$(uname -m)"
    case "${ARCH}" in
      x86_64)  MF_ARCH="x86_64" ;;
      aarch64) MF_ARCH="aarch64" ;;
      *) echo "Unsupported arch: ${ARCH}" && exit 1 ;;
    esac

    wget -q -O /tmp/Miniforge3.sh \
      "https://github.com/conda-forge/miniforge/releases/download/${MINIFORGE_VERSION}/Miniforge3-Linux-${MF_ARCH}.sh"
    bash /tmp/Miniforge3.sh -b -p /opt/conda
    rm -f /tmp/Miniforge3.sh

    export PATH=/opt/conda/bin:$PATH

    # mamba is already bundled with Miniforge — no need to install it separately.
    # Doing so can cause a version conflict. Just update it in-place.
    mamba update -n base mamba --yes
    mamba clean --all --yes

    # Create the environment
    echo "Creating openfold3 environment (linux-aarch64)..."
    mamba env create \
      -f /opt/openfold3/production-linux-aarch64.yml \
      --name openfold3

    # Activate and verify
    source activate openfold3

    # Override CPU-only conda-forge PyTorch with CUDA 12.6 pip wheels (aarch64 available since 2.6.0)
    pip install --root-user-action=ignore --force-reinstall --no-deps \
        torch==2.6.0+cu126 \
        --index-url https://download.pytorch.org/whl/cu126

    # Keep torchvision aligned with torch. On aarch64 only 0.25.0+cu126 is published.
    # Try the binary wheel first; if import fails, rebuild from source.
    TV_TAG="v0.25.0"
    if pip install --root-user-action=ignore --force-reinstall --no-deps \
        torchvision==0.25.0+cu126 \
        --index-url https://download.pytorch.org/whl/cu126; then
        : # wheel installed, will verify below
    else
        TV_TAG="main"
    fi

    # Verify torchvision can be imported. If not, rebuild from source matching the chosen tag.
    if ! python - <<'PY'
import sys
try:
    import torch, torchvision
except Exception as e:
    print("TOOLKIT_IMPORT_ERROR:", e, file=sys.stderr)
    sys.exit(1)
else:
    print("TOOLKIT_OK")
    sys.exit(0)
PY
    then
        echo "torchvision import failed; attempting to rebuild torchvision from source to match torch..."
        pip uninstall -y torchvision || true
        # Ensure setuptools with pkg_resources (removed in setuptools>=71 by default)
        # and packaging are available in the active env for --no-build-isolation builds.
        pip install --root-user-action=ignore "setuptools<71" packaging
        if [ "${TV_TAG}" = "main" ]; then
            SRC="git+https://github.com/pytorch/vision.git"
        else
            SRC="git+https://github.com/pytorch/vision.git@${TV_TAG}"
        fi
        # Pass the custom index so pip can resolve 'torch' as a build dependency
        # --no-build-isolation: reuse the already-installed torch instead of letting
        # pip's isolated build subprocess try (and fail) to download it from PyPI.
        pip install --root-user-action=ignore --no-deps --force-reinstall --no-binary :all: \
            --no-build-isolation \
            "${SRC}"
        # Re-test import
        if ! python - <<'PY'
import sys
try:
    import torch, torchvision
except Exception as e:
    print("TOOLKIT_IMPORT_ERROR_AFTER_BUILD:", e, file=sys.stderr)
    sys.exit(1)
else:
    print("TOOLKIT_OK_AFTER_BUILD")
    sys.exit(0)
PY
        then
            echo "Warning: torchvision import still failing after source build." >&2
        fi
    fi

    python -c "import torch, torchvision; print(f'PyTorch {torch.__version__}, TorchVision {getattr(torchvision,'__version__','<unknown>')}, CUDA available: {torch.cuda.is_available()}')"

    mamba clean --all --yes
    conda clean --all --yes

    # Install nvidia-cutlass so CUTLASS_PATH is not required at runtime
    pip install --root-user-action=ignore nvidia-cutlass

    # Install openfold3 in editable mode (no-deps: deps already in conda env)
    cd /opt/openfold3
    uv pip install --no-deps --editable .

    # Install third-party deps (if script exists)
    if [ -f /opt/openfold3/scripts/install_third_party_dependencies.sh ]; then
        bash /opt/openfold3/scripts/install_third_party_dependencies.sh
    fi

%environment
    export PATH=/opt/conda/envs/openfold3/bin:/opt/conda/bin:$PATH
    export CONDA_PREFIX=/opt/conda/envs/openfold3
    export CONDA_DEFAULT_ENV=openfold3
    export TORCH_CUDA_ARCH_LIST=9.0
    export CUDA_HOME=/usr/local/cuda
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export PATH=/usr/local/cuda/bin:$PATH
